{
  "name": "@deeppairing/mcp-server",
  "version": "0.1.16",
  "description": "Human-AI collaborative development framework — MCP server for Claude Code with companion web UI",
  "type": "module",
  "license": "MIT",
  "main": "./dist/standalone.js",
  "bin": {
    "deeppairing-server": "./dist/standalone.js",
    "deeppairing-daemon": "./dist/daemon/index.js",
    "deeppairing": "./dist/cli/init.js"
  },
  "files": [
    "dist/",
    "deeppairing.md",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "claude",
    "ai",
    "collaboration",
    "pair-programming",
    "code-review"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchjablonski/deepPairing"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', {recursive: true, force: true})\"",
    "build": "tsc && cd web && npx vite build && cd .. && node scripts/bundle-plugin.mjs",
    "start": "tsx src/standalone.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "prepublishOnly": "node -e \"require('node:fs').copyFileSync('../../README.md', 'README.md')\" && pnpm build",
    "lint": "eslint src web/src e2e --max-warnings 311"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@deeppairing/shared": "workspace:*",
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@shikijs/core": "4.0.2",
    "@shikijs/engine-oniguruma": "4.0.2",
    "@shikijs/langs": "4.0.2",
    "@shikijs/themes": "4.0.2",
    "hono": "^4.12.27",
    "mermaid": "^11.15.0",
    "nanoid": "^5.1.7",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.9.0",
    "motion": "^12.38.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "8.0.3",
    "vitest": "^4.1.9",
    "zustand": "^5.0.12"
  }
}
