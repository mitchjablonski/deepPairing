{
  "name": "@deeppairing/shared",
  "version": "0.1.3",
  "description": "Shared schemas and types for deepPairing",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./__fixtures__/*": {
      "development": "./src/__fixtures__/*.ts",
      "import": "./dist/__fixtures__/*.js",
      "default": "./dist/__fixtures__/*.js"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "keywords": [
    "deeppairing",
    "schemas",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchjablonski/deepPairing"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 6"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
